{
  "name": "sub-stalker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:vercel": "node scripts/vercel-build.mjs",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "npm run prisma:generate && tsc --noEmit",
    "test:auth": "npx dotenv -e .env.local -- node --import tsx --test tests/auth/*.test.ts",
    "test:invites": "dotenv -e .env.local -- node --import tsx --test tests/invites/*.test.ts",
    "test:mail": "dotenv -e .env.local -- node --import tsx --test tests/mail/*.test.ts",
    "test:dashboard": "dotenv -e .env.local -- node --import tsx --test tests/dashboard/*.test.ts",
    "email:dev": "email dev --dir lib/mail/templates",
    "db:up": "docker compose up -d db",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f db",
    "prisma:generate": "dotenv -e .env.local -- prisma generate",
    "db:migrate": "dotenv -e .env.local -- prisma migrate dev",
    "db:migrate:deploy:ci": "prisma migrate deploy",
    "db:migrate:deploy": "dotenv -e .env.local -- prisma migrate deploy",
    "db:reset": "dotenv -e .env.local -- prisma migrate reset",
    "db:studio": "dotenv -e .env.local -- prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^6.14.0",
    "@react-email/components": "^0.5.7",
    "@react-email/render": "^1.4.0",
    "easymde": "^2.20.0",
    "next": "14.2.5",
    "react": "18.3.1",
    "react-currency-flags": "^0.1.2",
    "react-dom": "18.3.1",
    "react-simplemde-editor": "^5.2.0",
    "resend": "^6.3.0",
    "styled-components": "^4.4.1"
  },
  "devDependencies": {
    "@types/node": "20.14.9",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "8.57.0",
    "eslint-config-next": "14.2.5",
    "prisma": "^6.14.0",
    "react-email": "^5.2.9",
    "tsx": "^4.20.5",
    "typescript": "5.5.3"
  }
}
